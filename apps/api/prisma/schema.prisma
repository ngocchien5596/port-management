generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lane {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  equipments Equipment[]
  incidents  Incident[]
  voyages    Voyage[]
}

model Equipment {
  id           String           @id @default(cuid())
  name         String           @unique
  laneId       String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  capacity     Decimal?         @default(100)
  manualStatus String?
  lane         Lane             @relation(fields: [laneId], references: [id])
  events       EquipmentEvent[]
  incidents    Incident[]
  voyages      Voyage[]         @relation("VoyageToEquipment")
  products     Product[]        @relation("EquipmentToProduct")
}

model EquipmentEvent {
  id          String    @id @default(cuid())
  equipmentId String
  type        String
  title       String
  description String?
  metadata    Json?
  userId      String?
  createdAt   DateTime  @default(now())
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  employee    Employee? @relation(fields: [userId], references: [id])
}

model Employee {
  id              String           @id @default(cuid())
  employeeCode    String           @unique
  fullName        String
  email           String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  account         Account?
  equipmentEvents EquipmentEvent[]
  notifications   Notification[]
  voyageEvents    VoyageEvent[]
  updatedProgress VoyageProgress[] @relation("ProgressUpdatedBy")
  createdProgress VoyageProgress[] @relation("ProgressCreatedBy")
}

model Account {
  id                  String    @id @default(cuid())
  employeeId          String    @unique
  passwordHash        String
  secretCode          String    @db.VarChar(50)
  role                Role      @default(STAFF)
  isActive            Boolean   @default(true)
  lastLogin           DateTime?
  passwordChangedAt   DateTime?
  secretCodeChangedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  employee            Employee  @relation(fields: [employeeId], references: [id])
}

model Vessel {
  id            String   @id @default(uuid())
  code          String   @unique
  customerName  String
  capacity      Decimal?
  customerPhone String?
  imoCode       String?  @unique
  vesselType    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  name          String?
  voyages       Voyage[]
}

model Product {
  id         String      @id @default(uuid())
  code       String      @unique
  name       String
  unit       String      @default("TON")
  type       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  voyages    Voyage[]
  equipments Equipment[] @relation("EquipmentToProduct")
}

model Voyage {
  id                 String           @id @default(uuid())
  voyageCode         Int              @unique @default(autoincrement())
  vesselId           String
  productId          String
  type               String
  priority           String           @default("NORMAL")
  queueNo            Int              @default(0)
  isYielded          Boolean          @default(false)
  eta                DateTime?
  etd                DateTime?
  totalVolume        Decimal?
  actualArrival      DateTime?
  actualDeparture    DateTime?
  readinessChecklist Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  laneId             String?
  status             VoyageStatus     @default(NHAP)
  cancelReason       String?
  equipmentId        String?
  procedureTimeHours Decimal?         @default(0)
  incidents          Incident[]
  notifications      Notification[]
  equipment          Equipment?       @relation("VoyageToEquipment", fields: [equipmentId], references: [id])
  lane               Lane?            @relation(fields: [laneId], references: [id])
  product            Product          @relation(fields: [productId], references: [id])
  vessel             Vessel           @relation(fields: [vesselId], references: [id])
  events             VoyageEvent[]
  progress           VoyageProgress[]

  @@index([laneId, status])
}

model Incident {
  id          String        @id @default(uuid())
  voyageId    String?
  type        String
  severity    String
  description String
  startTime   DateTime      @default(now())
  endTime     DateTime?
  userId      String
  createdAt   DateTime      @default(now())
  equipmentId String?
  laneId      String?
  scope       IncidentScope @default(VOYAGE)
  parentId    String?
  equipment   Equipment?    @relation(fields: [equipmentId], references: [id])
  lane        Lane?         @relation(fields: [laneId], references: [id])
  parent      Incident?     @relation("IncidentHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Incident[]    @relation("IncidentHierarchy")
  voyage      Voyage?       @relation(fields: [voyageId], references: [id])
}

model VoyageEvent {
  id          String    @id @default(uuid())
  voyageId    String
  type        String
  title       String
  description String?
  metadata    Json?
  userId      String?
  createdAt   DateTime  @default(now())
  employee    Employee? @relation(fields: [userId], references: [id])
  voyage      Voyage    @relation(fields: [voyageId], references: [id])
}

model VoyageProgress {
  id           String    @id @default(uuid())
  voyageId     String
  amount       Decimal
  cumulative   Decimal
  userId       String?
  notes        String?
  createdAt    DateTime  @default(now())
  hours        Decimal?
  productivity Decimal?
  endTime      DateTime?
  startTime    DateTime?
  updatedAt    DateTime?
  updatedById  String?
  shiftCode    String?
  updatedBy    Employee? @relation("ProgressUpdatedBy", fields: [updatedById], references: [id])
  employee     Employee? @relation("ProgressCreatedBy", fields: [userId], references: [id])
  voyage       Voyage    @relation(fields: [voyageId], references: [id])
}

model Notification {
  id        String    @id @default(uuid())
  type      String
  title     String
  message   String
  severity  String
  isRead    Boolean   @default(false)
  userId    String?
  voyageId  String?
  createdAt DateTime  @default(now())
  employee  Employee? @relation(fields: [userId], references: [id])
  voyage    Voyage?   @relation(fields: [voyageId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  MANAGER
  STAFF
}

enum IncidentScope {
  GLOBAL
  LANE
  EQUIPMENT
  VOYAGE
}

enum CheckinMethod {
  QR_SCAN
  MANUAL
  SELF_SCAN
}

enum CargoCategory {
  IMPORT
  EXPORT
}

enum VoyageStatus {
  THU_TUC
  DO_MON_DAU_VAO
  LAY_MAU
  LAM_HANG
  DO_MON_DAU_RA
  HOAN_THANH
  TAM_DUNG
  HUY_BO
  NHAP
}
