import { Request, Response } from 'express';
import { ZoneService } from '../services/zone.service';

export class ZoneController {
    static async getAll(req: Request, res: Response) {
        try {
            const zones = await ZoneService.getAll();
            res.json(zones);
        } catch (error: any) {
            res.status(500).json({ message: error.message });
        }
    }

    static async getById(req: Request, res: Response) {
        try {
            const zone = await ZoneService.getById(req.params.id);
            if (!zone) {
                return res.status(404).json({ message: 'Zone not found' });
            }
            res.json(zone);
        } catch (error: any) {
            res.status(500).json({ message: error.message });
        }
    }

    static async create(req: Request, res: Response) {
        try {
            const zone = await ZoneService.create(req.body);
            res.status(201).json(zone);
        } catch (error: any) {
            res.status(400).json({ message: error.message });
        }
    }

    static async update(req: Request, res: Response) {
        try {
            const zone = await ZoneService.update(req.params.id, req.body);
            res.json(zone);
        } catch (error: any) {
            res.status(400).json({ message: error.message });
        }
    }

    static async delete(req: Request, res: Response) {
        try {
            await ZoneService.delete(req.params.id);
            res.status(204).send();
        } catch (error: any) {
            res.status(400).json({ message: error.message });
        }
    }
}
